# ══════════════════════════════════════════════════════════════
#  The Third Eye — Environment Variables Reference
#  Copy to .env and fill in your values. Never commit .env.
# ══════════════════════════════════════════════════════════════

# ─── Core ──────────────────────────────────────────────────────
# Environment: development | production | test
ENVIRONMENT=development

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Secret key for JWT signing (generate: openssl rand -hex 32)
SECRET_KEY=your-secret-key-change-this-in-production

# ─── Database ──────────────────────────────────────────────────
POSTGRES_DB=jarvis
POSTGRES_USER=jarvis
# Strong password required — min 20 chars in production
POSTGRES_PASSWORD=change-me-strong-password

# Full async connection URL (auto-constructed from above in docker)
# Override manually if using an external database
DATABASE_URL=postgresql+asyncpg://jarvis:change-me-strong-password@localhost:5432/jarvis

# Sync URL used by Alembic migrations only
DATABASE_URL_SYNC=postgresql://jarvis:change-me-strong-password@localhost:5432/jarvis

# ─── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@localhost:6379/0

# ─── Encryption ────────────────────────────────────────────────
# AES-256 key for financial data at rest
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FINANCIAL_ENCRYPTION_KEY=your-fernet-key-here

# ─── Authentication (NextAuth.js) ──────────────────────────────
# NextAuth secret (generate: openssl rand -hex 32)
NEXTAUTH_SECRET=your-nextauth-secret-change-this
# Production: full URL including https
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — get from console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft OAuth — get from portal.azure.com (optional)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ─── AI Providers ──────────────────────────────────────────────
# Google AI (Gemini) — get from aistudio.google.com [REQUIRED - default router]
GOOGLE_AI_API_KEY=your-google-ai-api-key

# OpenAI — get from platform.openai.com [optional - for fallback/code tasks]
OPENAI_API_KEY=

# Anthropic — get from console.anthropic.com [optional - for fallback]
ANTHROPIC_API_KEY=

# Ollama base URL — local LLM for privacy mode (docker service or external)
OLLAMA_BASE_URL=http://ollama:11434

# Serper API — web search for Research Agent (Phase 2)
# Get from https://serper.dev — free tier available
SERPER_API_KEY=

# ─── Frontend ──────────────────────────────────────────────────
# Public API URL (accessible from browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Internal backend URL (server-to-server, not exposed)
BACKEND_URL=http://backend:8000

# ─── n8n Workflow Engine ───────────────────────────────────────
# n8n uses the main postgres instance with its own database
N8N_DB=n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-n8n-password
# Generate: openssl rand -hex 32
N8N_ENCRYPTION_KEY=your-n8n-encryption-key
N8N_WEBHOOK_URL=http://localhost:5678

# ─── Feature Flags ─────────────────────────────────────────────
# Enable/disable optional features
ENABLE_VOICE=false
ENABLE_LOCAL_AI=false
ENABLE_FINANCIAL_MODULE=false

# ─── Rate Limiting ─────────────────────────────────────────────
# Requests per minute per user for AI endpoints
AI_RATE_LIMIT_RPM=60

# Default monthly token budget per user (0 = unlimited)
DEFAULT_MONTHLY_TOKEN_BUDGET=0

# ─── Email (SMTP) — for email auth and notifications ───────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=The Third Eye <no-reply@yourdomain.com>
